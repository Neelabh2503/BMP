<?xml version="1.0" encoding="utf-8"?>
<!--  activity_detection_summary.xml
      Professional post‐capture summary screen for EdgeSite detection app.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- ══════════  HERO HEADER  ══════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A1A1A"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="24dp">

            <!-- Session complete badge -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="SESSION COMPLETE"
                android:textColor="#4CAF50"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:fontFamily="monospace" />

            <Space android:layout_width="0dp" android:layout_height="12dp" />

            <!-- Source title -->
            <TextView
                android:id="@+id/tvSummarySource"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                tools:text="Live Camera" />

            <Space android:layout_width="0dp" android:layout_height="6dp" />

            <!-- Date -->
            <TextView
                android:id="@+id/tvSummaryDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#99FFFFFF"
                android:textSize="13sp"
                android:fontFamily="monospace"
                tools:text="05 Apr 2026  14:22:08" />

            <Space android:layout_width="0dp" android:layout_height="4dp" />

            <!-- Duration -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱  "
                    android:textColor="#66FFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvSummaryDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#66FFFFFF"
                    android:textSize="13sp"
                    tools:text="2m 34s" />

            </LinearLayout>

        </LinearLayout>

        <!-- ══════════  STAT PILLS  ══════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="4dp">

            <!-- Frames with detection -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:id="@+id/tvStatFrames"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    tools:text="312" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FRAMES"
                    android:textColor="#66FFFFFF"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Total detections -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:id="@+id/tvStatDetections"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#4CAF50"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    tools:text="847" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DETECTIONS"
                    android:textColor="#66FFFFFF"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Unique classes -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:id="@+id/tvStatClasses"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#2196F3"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    tools:text="5" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CLASSES"
                    android:textColor="#66FFFFFF"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- ══════════  OBJECTS DETECTED  ══════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OBJECTS DETECTED"
                android:textColor="#66FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:paddingBottom="12dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvClassSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:itemCount="4"
                tools:listitem="@layout/item_class_summary" />

            <!-- Empty state -->
            <TextView
                android:id="@+id/tvNoObjects"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No objects detected in this session."
                android:textColor="#44FFFFFF"
                android:textSize="14sp"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ══════════  TIMELINE  ══════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DETECTION TIMELINE"
                    android:textColor="#66FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="latest first"
                    android:textColor="#44FFFFFF"
                    android:textSize="11sp" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTimeline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:itemCount="8"
                tools:listitem="@layout/item_timeline_entry" />

            <TextView
                android:id="@+id/tvTimelineEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No timeline data available."
                android:textColor="#44FFFFFF"
                android:textSize="14sp"
                android:gravity="center"
                android:padding="12dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ══════════  ACTION BUTTONS  ══════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp">

            <Button
                android:id="@+id/btnSummaryShare"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Share"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_outline"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnSummaryClose"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Close"
                android:textColor="#000000"
                android:background="@drawable/btn_solid"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
